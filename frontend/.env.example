# Use these when the app is served over HTTPS (e.g. https://gov-exam.nexgenai.asia)
# to avoid Mixed Content and "Failed to fetch" errors. Set to your backend's HTTPS URL.
REACT_APP_API_URL=https://gov-exam.nexgenai.asia/api
REACT_APP_BACKEND_URL=https://gov-exam.nexgenai.asia

# Optional: admin default secret (used if backend doesn't return one)
# REACT_APP_ADMIN_SECRET=admin123

# Optional: Google Analytics (GA4) measurement ID for page views and events
# REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# https://analytics.google.com/analytics/web/#/a367050632p528058922/reports/intelligenthome

# nexgenai.asia@gmail.com

# Optional: Google reCAPTCHA v2 site key (for login/signup/admin login)
# REACT_APP_RECAPTCHA_SITE_KEY=your_site_key_here

# https://www.google.com/recaptcha/admin/site/747087997
